{{ header(file_name) }}
`ifndef  {{ block_name | upper }}_ENV__SV
`define  {{ block_name | upper }}_ENV__SV

class {{ block_name }}_env extends uvm_env;
    `uvm_component_utils_begin({{ block_name }}_env)
    `uvm_component_utils_end

    {{ block_name }}_env_cfg    m_cfg;
{% for agent in agents %}
    {{ agent.name }}_agent      m_{{ agent.name }}_agt;
{% endfor %}
    {{ block_name }}_rm         m_rm;
    {{ block_name }}_checker    m_scb;
    {{ block_name }}_vsqr       m_vsqr;

    // dec connect to rm fifo
{% for agent in agents %}
    uvm_tlm_analysis_fifo#(uvm_sequence_item)   m_{{ agent.name }}_agt_mon_to_rm_fifo;
{% endfor %}
    // dec connect to scb fifo
{% for agent in agents %}
    uvm_tlm_analysis_fifo#(uvm_sequence_item)   m_rm_{{ agent.name }}_trans_to_scb_fifo;
    uvm_tlm_analysis_fifo#(uvm_sequence_item)   m_agt_{{ agent.name }}_trans_to_scb_fifo;
{% endfor %}

    extern function new(string name="{{ block_name }}_env", uvm_component parent=null);
    extern virtual function void build_phase(uvm_phase phase);
    extern virtual function void connect_phase(uvm_phase phase);
endclass

function {{ block_name }}_env::new(string name="{{ block_name }}_env", uvm_component parent=null);
    super.new(name, parent);
endfunction : new

function void {{ block_name }}_env::build_phase(uvm_phase phase);
    super.build_phase(phase);
    if(this.m_cfg == null) begin
        this.m_cfg = {{ block_name }}_env_cfg::type_id::create("m_cfg", this);
    end
    // create agents
{% for agent in agents %}
    m_{{ agent.name }}_agt = {{ agent.name }}_agent::type_id::create("m_{{ agent.name }}_agt", this);
    m_{{ agent.name }}_agt.m_cfg = m_cfg.m_{{ agent.name }}_agt_cfg;
{% endfor %}
    // create rm and scb
    m_rm   = {{ block_name }}_rm::type_id::create("m_rm", this);
    m_scb  = {{ block_name }}_checker::type_id::create("m_scb", this);
    m_vsqr = {{ block_name }}_vsqr::type_id::create("m_vsqr", this);
    // new connect to rm fifo
{% for agent in agents %}
    m_{{ agent.name }}_agt_mon_to_rm_fifo   = new($sformatf("m_{{ agent.name }}_agt_mon_to_rm_fifo"), this);
{% endfor %}
    // new connect to scb fifo
{% for agent in agents %}
    m_rm_{{ agent.name }}_trans_to_scb_fifo  = new($sformatf("m_rm_{{ agent.name }}_trans_to_scb_fifo"), this);
    m_agt_{{ agent.name }}_trans_to_scb_fifo = new($sformatf("m_agt_{{ agent.name }}_trans_to_scb_fifo"), this);
{% endfor %}
endfunction : build_phase

function void {{ block_name }}_env::connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // connect to rm fifo
{% for agent in agents %}
    m_{{ agent.name }}_agt.m_mon.m_ap.connect(m_{{ agent.name }}_agt_mon_to_rm_fifo.analysis_export);
    m_rm.m_from_{{ agent.name }}_agt_mon_port.connect(m_{{ agent.name }}_agt_mon_to_rm_fifo.blocking_get_export);
{% endfor %}
    // connect to scb fifo
{% for agent in agents %}
    m_rm.m_rm_{{ agent.name }}_trans_to_scb_port.connect(m_rm_{{ agent.name }}_trans_to_scb_fifo.analysis_export);
    m_scb.m_from_rm_{{ agent.name }}_trans_port.connect(m_rm_{{ agent.name }}_trans_to_scb_fifo.blocking_get_export);
    m_{{ agent.name }}_agt.m_mon.m_ap.connect(m_agt_{{ agent.name }}_trans_to_scb_fifo.analysis_export);
    m_scb.m_from_agt_{{ agent.name }}_trans_port.connect(m_agt_{{ agent.name }}_trans_to_scb_fifo.blocking_get_export);
{% endfor %}
    // connect vsqr
{% for agent in agents %}
    m_vsqr.m_{{ agent.name }}_sqr = this.m_{{ agent.name }}_agt.m_sqr;
{% endfor %}
endfunction : connect_phase

`endif
