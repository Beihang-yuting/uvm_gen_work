{{ header(file_name) }}
`ifndef  {{ name_upper }}_DRV__SV
`define  {{ name_upper }}_DRV__SV

class {{ name }}_drv extends uvm_driver #({{ name }}_trans);
    `uvm_component_utils_begin({{ name }}_drv)
    `uvm_component_utils_end

    {{ name }}_agt_cfg    m_cfg;
    virtual {{ name }}_if m_vif;
    int                   m_get_trans_cnt;
    common_self_debug_scb#({{ name }}_trans)  m_debug_scb;

    extern function new(string name="{{ name }}_drv", uvm_component parent=null);
    extern virtual function void build_phase(uvm_phase phase);
    extern virtual task run_phase(uvm_phase phase);
    extern virtual task master_drive();
    extern virtual task slave_drive();
    extern virtual task reset_signals();
    extern virtual task reset_callback();
endclass

function {{ name }}_drv::new(string name="{{ name }}_drv", uvm_component parent=null);
    super.new(name, parent);
    m_get_trans_cnt = 0;
endfunction : new

function void {{ name }}_drv::build_phase(uvm_phase phase);
    super.build_phase(phase);
    if(!uvm_config_db#(virtual {{ name }}_if)::get(this, "", "m_vif", m_vif)) begin
        `uvm_fatal(get_full_name, "virtual interface must be set for driver!!!")
    end
endfunction : build_phase

task {{ name }}_drv::run_phase(uvm_phase phase);
    super.run_phase(phase);
    forever begin
        // 等待复位结束
        wait(m_vif.rst_n === 1'b1);
        `uvm_info(get_full_name, "reset released, starting driver", UVM_MEDIUM)
        fork
            begin
                case(m_cfg.m_mode)
                    AGENT_MASTER, AGENT_ONLY_MASTER: master_drive();
                    AGENT_SLAVE, AGENT_ONLY_SLAVE:   slave_drive();
                    default: `uvm_fatal(get_full_name, "only-monitor mode should not have driver")
                endcase
            end
            begin
                @(negedge m_vif.rst_n);
                `uvm_info(get_full_name, "reset detected, stopping driver", UVM_MEDIUM)
            end
        join_any
        disable fork;
        reset_signals();
        reset_callback();
    end
endtask : run_phase

task {{ name }}_drv::master_drive();
    //TODO: 实现 master 驱动逻辑
    `uvm_info(get_full_name, "master_drive started", UVM_NONE)
endtask : master_drive

task {{ name }}_drv::slave_drive();
    //TODO: 实现 slave 驱动逻辑
    `uvm_info(get_full_name, "slave_drive started", UVM_NONE)
endtask : slave_drive

// 复位时清理总线信号（用户 override 实现具体协议信号归零）
task {{ name }}_drv::reset_signals();
    //TODO: 将输出信号拉到初始状态
    // 例如:
    // m_vif.drv_cb.valid <= 1'b0;
    // m_vif.drv_cb.data  <= '0;
endtask : reset_signals

// 用户自定义复位回调（默认空，用户可 override 注册自定义复位动作）
task {{ name }}_drv::reset_callback();
endtask : reset_callback

`endif
