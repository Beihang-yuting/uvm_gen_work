`ifndef  COMMON_DRAW_TABLE__SV
`define  COMMON_DRAW_TABLE__SV


class common_draw_table;
    int m_coloum_num;
    int m_coloum_width;
    int m_content_num;
    string m_line_content_q[int][$];

    function new();
        this.m_coloum_num   = 0;
        this.m_coloum_width = 20;
        this.m_content_num  = 0;
    endfunction

    function string gen_head_line();
        string ret_str;
        string tmp_str;
        int i,j,k;
        ret_str = "-";
        for(int i=0;i<this.m_coloum_num;i++) begin
            tmp_str = {this.m_coloum_width{"_"}};
            ret_str = {ret_str,tmp_str};
        end
        ret_str[0] = " ";
        ret_str[ret_str.len-1]=" ";
        return ret_str;
    endfunction

    function string gen_underline_one_line();
        string ret_str;
        string tmp_str;
        int i,j,k;
        ret_str = {"|",{this.m_coloum_num*this.m_coloum_width-1{"_"}},"|"};
        return ret_str;
    endfunction

    function string gen_empty_line();
        string ret_str;
        ret_str = {"|",{this.m_coloum_num*this.m_coloum_width-1{" "}},"|"};
        return ret_str;
    endfunction

    function void insert_line_content(string in_line_str);
        int i,j,k;
        string insert_str[$];
        string get_str;
        string tmp_str;
        int start_index,end_index;
        for(i=0;i<in_line_str.len;i++) begin
            if(in_line_str[i] != " ") begin
                start_index = i;
                break;
            end
        end
        j=0;
        for(i=0;i<in_line_str.len;i++) begin
            if(in_line_str[in_line_str.len-1-i] == " ") begin
                j++;
            end
            else begin
                break;
            end
        end
        end_index = in_line_str.len-j;
        k=0;
        get_str = "";
        for(i = start_index;i<end_index;i++) begin
            get_str = {get_str,in_line_str[i]};
            k++;
        end
        k = 0;
        tmp_str = "";
        for(i=0;i<get_str.len;i++) begin
            if(get_str[i] == " ") begin
                if(tmp_str.len>0) begin
                    insert_str.push_back(tmp_str);
                    k = 0;
                    tmp_str = "";
                end
            end
            else begin
                tmp_str = {tmp_str,get_str[i]};
                k++;
            end
        end
        insert_str.push_back(tmp_str);
        this.insert_content(insert_str);
    endfunction

    function void insert_content(string insert_str[$]);
        int i,j,k;
        string ret_str;
        this.m_line_content_q[this.m_content_num] = insert_str;
        if(insert_str.size()>this.m_coloum_num) begin
            this.m_coloum_num = insert_str.size();
        end
        if(insert_str.size()>1) begin
            j=0;
            for(i=0;i<insert_str.size();i++) begin
                if(insert_str[i].len()>j) begin
                    j = insert_str[i].len;
                end
            end
            if(j>=(this.m_coloum_width-1)) begin
                this.m_coloum_width = j+2;
            end
        end
        this.m_content_num++;
    endfunction

    function string gen_content(string insert_str[$]);
        string ret_str;
        string tmp_str;
        string under_line_str;
        int i,j,k;
        int str_len,start_index;
        int column_width,tab_width;
        tab_width = this.m_coloum_num*this.m_coloum_width + 1;
        under_line_str = this.gen_underline_one_line();
        if( insert_str.size() == 1) begin
            ret_str = {"|",{(tab_width-2){" "}},"|"};
            str_len = insert_str[0].len();
            start_index = (tab_width -str_len)/2;
            for(i=0;i<str_len;i++) begin
                ret_str[i+start_index] = insert_str[0][i];
            end
        end
        else begin
            column_width = tab_width / insert_str.size();
            ret_str = {"|",{(tab_width-2){" "}},"|"};
            for(i=0;i<(insert_str.size()-1);i++) begin
                start_index = 1+ column_width*(i+1);
                ret_str[start_index] = "|";
                under_line_str[start_index] = "|";
            end
            for(i=0;i<insert_str.size();i++) begin
                str_len = insert_str[i].len;
                start_index = column_width*i+1 + ((column_width - str_len)/2);
                for(j=0;j<insert_str[i].len;j++) begin
                    ret_str[start_index+j] = insert_str[i][j];
                end
            end
        end
        ret_str = {ret_str,"\n",under_line_str};
        return ret_str;
    endfunction

    function void display_table();
        int i,j,k;
        string line_str_q[$];
        $display("%s",this.gen_head_line);
        for(i=0;i<this.m_content_num;i++) begin
            line_str_q = this.m_line_content_q[i];
            $display("%s",this.gen_content(line_str_q));
        end
        $display("");
    endfunction

    function void clean_table_content();
        this.m_line_content_q.delete();
        this.m_content_num = 0;
        this.m_coloum_width = 20;
        this.m_coloum_num = 0;
    endfunction

endclass

`endif
