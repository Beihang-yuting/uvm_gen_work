//===============================================================
// 二、Coverpoint（覆盖点）
//---------------------------------------------------------------
// 定义要覆盖的变量和 bin 划分方式
//===============================================================

// covergroup cg_coverpoint;
//
//     // ----- 2.1 自动 bin（默认 64 个 bin）-----
//     // 自动将值域均匀划分
//     cp_auto: coverpoint addr;
//
//     // 限制自动 bin 数量
//     cp_auto_16: coverpoint addr {
//         option.auto_bin_max = 16;
//     }
//
//     // ----- 2.2 显式 bin -----
//     cp_cmd: coverpoint cmd {
//         bins read_cmd  = {8'h01};              // 单个值
//         bins write_cmd = {8'h02};
//         bins cfg_cmd   = {8'h10, 8'h11, 8'h12}; // 多个值归为一个 bin
//         bins burst_cmd = {[8'h20:8'h2F]};      // 值范围
//         bins others    = default;               // 其余所有值
//     }
//
//     // ----- 2.3 枚举类型覆盖 -----
//     // typedef enum {IDLE, READ, WRITE, BURST} state_e;
//     cp_state: coverpoint state {
//         bins idle  = {IDLE};
//         bins read  = {READ};
//         bins write = {WRITE};
//         bins burst = {BURST};
//     }
//
//     // ----- 2.4 数组 bin（每个值一个 bin）-----
//     cp_id: coverpoint trans_id {
//         bins id[] = {[0:15]};     // 生成 16 个独立的 bin: id[0], id[1], ...
//     }
//
//     // ----- 2.5 非法值 bin -----
//     // illegal_bins 匹配时报错，用于检查不应出现的值
//     cp_size: coverpoint burst_size {
//         bins valid_sizes[] = {1, 2, 4, 8, 16};
//         illegal_bins bad_size = {0};            // size=0 是非法的
//         illegal_bins too_large = {[32:$]};      // 超过 16 也是非法的
//     }
//
//     // ----- 2.6 忽略值 bin -----
//     // ignore_bins 不计入覆盖率统计
//     cp_addr: coverpoint addr[15:0] {
//         bins low_range  = {[16'h0000:16'h0FFF]};
//         bins mid_range  = {[16'h1000:16'h7FFF]};
//         bins high_range = {[16'h8000:16'hFFFF]};
//         ignore_bins reserved = {[16'hFF00:16'hFFFF]}; // 保留地址不统计
//     }
//
// endgroup


//===============================================================
// 三、Transition Coverage（转换覆盖率）
//---------------------------------------------------------------
// 覆盖信号值的变化序列（状态跳转）
//===============================================================

// covergroup cg_transition;
//
//     // ----- 3.1 两值转换 -----
//     // 场景：覆盖状态机的所有合法跳转
//     cp_state_trans: coverpoint state {
//         bins idle_to_read  = (IDLE  => READ);
//         bins idle_to_write = (IDLE  => WRITE);
//         bins read_to_idle  = (READ  => IDLE);
//         bins write_to_idle = (WRITE => IDLE);
//         bins read_to_write = (READ  => WRITE);  // 是否支持直接跳转?
//     }
//
//     // ----- 3.2 多值转换序列 -----
//     // 场景：覆盖连续三拍的状态变化
//     cp_state_seq: coverpoint state {
//         bins full_read  = (IDLE => READ  => IDLE);
//         bins full_write = (IDLE => WRITE => IDLE);
//         bins back2back  = (READ => IDLE  => READ);
//     }
//
//     // ----- 3.3 重复转换 -----
//     cp_repeat: coverpoint cmd {
//         bins consecutive_reads  = (READ  [*3]);  // 连续 3 次读
//         bins consecutive_writes = (WRITE [*3]);  // 连续 3 次写
//         bins rw_alternate = (READ => WRITE [*2:4]); // 读后连续写 2~4 次
//     }
//
// endgroup


//===============================================================
// 四、Cross Coverage（交叉覆盖率）
//---------------------------------------------------------------
// 覆盖多个 coverpoint 的笛卡尔积组合
//===============================================================

// covergroup cg_cross;
//
//     cp_cmd: coverpoint cmd {
//         bins read  = {CMD_READ};
//         bins write = {CMD_WRITE};
//     }
//
//     cp_size: coverpoint burst_size {
//         bins single = {1};
//         bins burst4 = {4};
//         bins burst8 = {8};
//     }
//
//     cp_addr_region: coverpoint addr[31:28] {
//         bins region_0 = {4'h0};
//         bins region_1 = {4'h1};
//         bins region_F = {4'hF};
//     }
//
//     // ----- 4.1 基本交叉 -----
//     // 覆盖 cmd x size 的所有组合（2 x 3 = 6 个 bin）
//     cx_cmd_size: cross cp_cmd, cp_size;
//
//     // ----- 4.2 带过滤的交叉 -----
//     // 只覆盖感兴趣的组合，忽略不需要的
//     cx_cmd_addr: cross cp_cmd, cp_addr_region {
//         // 忽略 region_F 的写操作（该区域只读）
//         ignore_bins no_write_regionF = binsof(cp_cmd.write) && binsof(cp_addr_region.region_F);
//     }
//
//     // ----- 4.3 三路交叉 -----
//     cx_all: cross cp_cmd, cp_size, cp_addr_region {
//         // 限制总 bin 数，只关注特定组合
//         bins read_burst8_region0 = binsof(cp_cmd.read) && binsof(cp_size.burst8) && binsof(cp_addr_region.region_0);
//     }
//
// endgroup


