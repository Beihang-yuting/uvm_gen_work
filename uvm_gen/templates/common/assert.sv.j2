//     assert_data_no_x: assert property (p_data_no_x);
// endmodule

// ----- 6.2 在 testbench 中 bind -----
// bind {{ block_name }}_top {{ block_name }}_sva_checker u_sva_checker (
//     .clk    (clk),
//     .rst_n  (rst_n),
//     .valid  (axi_valid),
//     .ready  (axi_ready),
//     .data   (axi_data)
// );


//===============================================================
// 七、断言控制（运行时开关）
//---------------------------------------------------------------
// $assertoff(0, "<层次>");     关闭指定层次的所有断言
// $asserton(0, "<层次>");      开启指定层次的所有断言
// $assertkill(0, "<层次>");    杀掉正在评估中的断言
//
// 使用场景：复位阶段关闭断言，避免误报
//===============================================================

// initial begin
//     // 复位期间关闭所有断言
//     $assertoff(0, "harness.u_dut");
//     @(posedge rst_n);
//     // 复位结束后延迟几个周期再开启
//     repeat(5) @(posedge clk);
//     $asserton(0, "harness.u_dut");
// end

`endif
