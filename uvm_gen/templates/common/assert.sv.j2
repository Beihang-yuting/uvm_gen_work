`ifndef  {{ block_name | upper }}_ASSERT__SV
`define  {{ block_name | upper }}_ASSERT__SV

//===============================================================
// SVA (SystemVerilog Assertion) 断言参考模板
//
// *** 本文件为参考模板，未加入 filelist，用户按需引入 ***
//
// 功能：提供常用断言写法的完整示例，帮助验证工程师快速上手 SVA
// 使用：将需要的断言复制到你的模块或 bind 文件中
// 加载：若需使用，在 env.f 中添加  ../env/{{ block_name }}_assert.sv
//===============================================================


//===============================================================
// 一、即时断言（Immediate Assertion）
//---------------------------------------------------------------
// 在 always 块或 initial 块中使用，检查当前时刻的条件
// 类似 if 检查，但可被 EDA 工具统计和追踪
//===============================================================

// 1.1 基本用法
// always @(posedge clk) begin
//     // 检查数据有效时地址不能为全 X
//     assert (!(data_valid && $isunknown(addr)))
//         else `uvm_error("ASSERT", $sformatf("地址包含 X 态: addr=0x%0h", addr))
//
//     // 简写形式（断言通过时无动作）
//     assert (fifo_count <= FIFO_DEPTH);
//
//     // 带 pass 和 fail 动作
//     assert (resp == RESP_OK)
//         $display("响应正确");
//         else $error("响应错误: resp=%0d", resp);
// end

// 1.2 三种严重级别
// assert (condition) else $warning("可忽略的问题");      // 警告
// assert (condition) else $error("需要关注的问题");       // 错误
// assert (condition) else $fatal(1, "致命错误，停止仿真"); // 致命


//===============================================================
// 二、并发断言（Concurrent Assertion）
//---------------------------------------------------------------
// 在 module/interface 级别声明，跨时钟周期检查时序行为
// 仿真器在每个采样时钟沿自动评估
//===============================================================

// ----- 基本语法 -----
// property <属性名>;
//     @(posedge clk) disable iff (!rst_n)
//     <序列表达式>;
// endproperty
//
// assert_<名称>: assert property (<属性名>)
//     else `uvm_error("SVA", "断言失败描述");

// ----- 2.1 请求-应答（Request-Acknowledge） -----
// 场景：req 拉高后，ack 必须在 1~4 个周期内响应
//
// property p_req_ack;
//     @(posedge clk) disable iff (!rst_n)
//     req |-> ##[1:4] ack;
// endproperty
// assert_req_ack: assert property (p_req_ack)
//     else `uvm_error("SVA", "req 拉高后 4 周期内未收到 ack")

// ----- 2.2 AXI 握手协议 -----
// 场景：valid 拉高后，在 ready 握手之前 valid 不能拉低
//
// property p_valid_hold;
//     @(posedge clk) disable iff (!rst_n)
//     (valid && !ready) |=> valid;
// endproperty
// assert_valid_hold: assert property (p_valid_hold)
//     else `uvm_error("SVA", "valid 在 ready 响应前被拉低，违反握手协议")

// ----- 2.3 数据稳定性 -----
// 场景：valid 期间 data 必须保持稳定
//
// property p_data_stable;
//     @(posedge clk) disable iff (!rst_n)
//     (valid && !ready) |=> ($stable(data));
// endproperty
// assert_data_stable: assert property (p_data_stable)
//     else `uvm_error("SVA", "valid 期间 data 发生变化")


//===============================================================
// 三、时序运算符详解
//---------------------------------------------------------------
// |->     : 重叠蕴含（同一周期检查后续条件）
// |=>     : 非重叠蕴含（下一周期开始检查后续条件）
// ##N     : 延迟 N 个周期
// ##[M:N] : 延迟 M 到 N 个周期（范围）
// [*N]    : 连续重复 N 次
// [*M:N]  : 连续重复 M 到 N 次
// $rose   : 信号上升沿（0->1）
// $fell   : 信号下降沿（1->0）
// $stable : 信号保持不变
// $past   : 上一周期的值
// $isunknown : 信号包含 X 或 Z
//===============================================================

// ----- 3.1 延迟 -----
// 场景：写使能拉高后，恰好 2 个周期后数据应出现在总线上
//
// property p_write_latency;
//     @(posedge clk) disable iff (!rst_n)
//     wr_en |-> ##2 data_bus_valid;
// endproperty

// ----- 3.2 连续重复 -----
// 场景：burst 传输必须连续 4 拍有效
//
// property p_burst4;
//     @(posedge clk) disable iff (!rst_n)
//     burst_start |-> valid [*4];
// endproperty

// ----- 3.3 信号跳变检测 -----
// 场景：中断信号上升沿后，中断状态寄存器必须在 3 周期内置位
//
// property p_irq_status;
//     @(posedge clk) disable iff (!rst_n)
//     $rose(irq) |-> ##[1:3] irq_status;
// endproperty

// ----- 3.4 使用 $past -----
// 场景：检查计数器单调递增（每周期 +1 或保持）
//
// property p_counter_monotonic;
//     @(posedge clk) disable iff (!rst_n)
//     (counter == $past(counter) + 1) || (counter == $past(counter));
// endproperty


//===============================================================
// 四、序列（Sequence）
//---------------------------------------------------------------
// 可复用的时序模式，被 property 引用
//===============================================================

// ----- 4.1 基本序列 -----
// sequence seq_handshake;
//     valid ##[0:$] ready;      // valid 之后任意周期 ready 响应
// endsequence

// ----- 4.2 带参数的序列 -----
// sequence seq_delay_n(sig, n);
//     sig ##n 1'b1;
// endsequence

// ----- 4.3 序列组合 -----
// 场景：写操作完整流程 = 地址阶段 -> 数据阶段 -> 响应阶段
//
// sequence seq_addr_phase;
//     addr_valid && addr_ready;
// endsequence
//
// sequence seq_data_phase;
//     data_valid ##[1:8] data_ready;
// endsequence
//
// sequence seq_resp_phase;
//     resp_valid && resp_ready;
// endsequence
//
// property p_write_flow;
//     @(posedge clk) disable iff (!rst_n)
//     seq_addr_phase |-> ##1 seq_data_phase ##1 seq_resp_phase;
// endproperty


//===============================================================
// 五、常用断言场景
//===============================================================

// ----- 5.1 FIFO 溢出/下溢检查 -----
// property p_fifo_no_overflow;
//     @(posedge clk) disable iff (!rst_n)
//     !(fifo_push && fifo_full);
// endproperty
// assert_fifo_no_overflow: assert property (p_fifo_no_overflow)
//     else `uvm_error("SVA", "FIFO 溢出: push 时 FIFO 已满")
//
// property p_fifo_no_underflow;
//     @(posedge clk) disable iff (!rst_n)
//     !(fifo_pop && fifo_empty);
// endproperty
// assert_fifo_no_underflow: assert property (p_fifo_no_underflow)
//     else `uvm_error("SVA", "FIFO 下溢: pop 时 FIFO 已空")

// ----- 5.2 独热码检查 -----
// property p_onehot;
//     @(posedge clk) disable iff (!rst_n)
//     state_valid |-> $onehot(state);
// endproperty
// assert_onehot: assert property (p_onehot)
//     else `uvm_error("SVA", $sformatf("状态非独热码: state=0x%0h", state))

// ----- 5.3 互斥检查 -----
// property p_mutex;
//     @(posedge clk) disable iff (!rst_n)
//     !(rd_en && wr_en);     // 读写不能同时有效
// endproperty
// assert_mutex: assert property (p_mutex)
//     else `uvm_error("SVA", "rd_en 和 wr_en 同时有效")

// ----- 5.4 无 X/Z 态检查 -----
// property p_no_x;
//     @(posedge clk) disable iff (!rst_n)
//     data_valid |-> !$isunknown(data);
// endproperty
// assert_no_x: assert property (p_no_x)
//     else `uvm_error("SVA", "data_valid 时 data 包含 X/Z")

// ----- 5.5 超时检查 -----
// 场景：事务必须在 100 个周期内完成
//
// property p_timeout;
//     @(posedge clk) disable iff (!rst_n)
//     trans_start |-> ##[1:100] trans_done;
// endproperty
// assert_timeout: assert property (p_timeout)
//     else `uvm_error("SVA", "事务超时: 100 周期内未完成")

// ----- 5.6 复位行为检查 -----
// 场景：复位时所有输出必须归零
//
// property p_reset_clear;
//     @(posedge clk)
//     !rst_n |-> (data_out == '0) && (valid_out == 1'b0);
// endproperty
// assert_reset_clear: assert property (p_reset_clear)
//     else `uvm_error("SVA", "复位期间输出未清零")


