`ifndef  {{ name_upper }}_MON__SV
`define  {{ name_upper }}_MON__SV


class {{ name }}_mon extends uvm_monitor;

    `uvm_component_utils_begin({{ name }}_mon)
    `uvm_component_utils_end

    {{ name }}_agt_cfg                        m_cfg;
    virtual {{ name }}_if                     m_vif;
    uvm_analysis_port#({{ name }}_trans)      m_ap;
    common_self_debug_scb#({{ name }}_trans)  m_debug_scb;
    int                                       m_mon_trans_cnt;

    extern function new(string name="{{ name }}_mon", uvm_component parent=null);
    extern virtual function void build_phase(uvm_phase phase);
    extern virtual task run_phase(uvm_phase phase);
    extern virtual task mon_transaction();
    extern virtual task reset_callback();

endclass

function {{ name }}_mon::new(string name="{{ name }}_mon", uvm_component parent=null);
    super.new(name, parent);
    this.m_mon_trans_cnt = 0;
endfunction : new

function void {{ name }}_mon::build_phase(uvm_phase phase);
    super.build_phase(phase);

    if(!uvm_config_db#(virtual {{ name }}_if)::get(this, "", "m_vif", m_vif)) begin
        `uvm_fatal(get_full_name, "virtual interface must be set for agent_monitor!!!")
    end
    m_ap = new("m_ap", this);
endfunction

task {{ name }}_mon::run_phase(uvm_phase phase);
    super.run_phase(phase);
    forever begin
        // 等待复位结束
        wait(m_vif.rst_n === 1'b1);
        `uvm_info(get_full_name, "reset released, starting monitor", UVM_MEDIUM)
        fork
            mon_transaction();
            begin
                @(negedge m_vif.rst_n);
                `uvm_info(get_full_name, "reset detected, stopping monitor", UVM_MEDIUM)
            end
        join_any
        disable fork;
        reset_callback();
    end
endtask

