`ifndef  {{ block_name | upper }}_RM__SV
`define  {{ block_name | upper }}_RM__SV

class {{ block_name }}_rm extends uvm_component;

    `uvm_component_utils_begin({{ block_name }}_rm)
    `uvm_component_utils_end

    // dec common rm member

    // dec in_port — self-contained: use uvm_analysis_imp to receive data directly
{% for agent in agents %}
    `uvm_analysis_imp_decl(_from_{{ agent.name }}_agt)
    uvm_analysis_imp_from_{{ agent.name }}_agt#(uvm_sequence_item, {{ block_name }}_rm)   m_from_{{ agent.name }}_agt_imp;
{% endfor %}

    extern function new(string name, uvm_component parent);
    extern virtual function void build_phase(uvm_phase phase);
    extern virtual task run_phase(uvm_phase phase);
{% for agent in agents %}
    extern virtual function void write_from_{{ agent.name }}_agt(uvm_sequence_item tr);
{% endfor %}

endclass

function {{ block_name }}_rm::new(string name, uvm_component parent);
    super.new(name, parent);
endfunction

function void {{ block_name }}_rm::build_phase(uvm_phase phase);
    super.build_phase(phase);
{% for agent in agents %}
    m_from_{{ agent.name }}_agt_imp = new("m_from_{{ agent.name }}_agt_imp", this);
{% endfor %}
endfunction

task {{ block_name }}_rm::run_phase(uvm_phase phase);
    super.run_phase(phase);
    `uvm_info(get_full_name(), "rm run_phase start", UVM_NONE);
endtask

{% for agent in agents %}
function void {{ block_name }}_rm::write_from_{{ agent.name }}_agt(uvm_sequence_item tr);
    {{ agent.name }}_trans cast_tr;
    if(!$cast(cast_tr, tr)) begin
        `uvm_fatal(get_full_name(), $sformatf("trans type should be {{ agent.name }}_trans"));
    end
    // TODO: implement reference model logic for {{ agent.name }}
endfunction

{% endfor %}
`endif
