function void tc_base::build_phase(uvm_phase phase);
    super.build_phase(phase);
    m_env = {{ block_name }}_env::type_id::create("m_env",this);
endfunction

task tc_base::reset_phase(uvm_phase phase);
    int i,j,k;
    phase.raise_objection(this);
    super.reset_phase(phase);
    i = $urandom_range(3,10);
    if(($urandom()%2) == 1) begin
        harness.rst_n = 1'b1;
    end
    else begin
        harness.rst_n = 1'b0;
    end
    repeat(i) @(posedge harness.clk);
    harness.rst_n = 1'b0;
    i = $urandom_range(10,20);
    repeat(i) @(posedge harness.clk);
    harness.rst_n = 1'b0;
    repeat(10) @(posedge harness.clk);
    phase.drop_objection(this);
endtask

function void tc_base::report_phase(uvm_phase phase);
    uvm_report_server  server;
    int  err_num,war_num,fatal_num;
    super.report_phase(phase);

    server     = get_report_server();
    server.enable_report_id_count_summary = 0; //set fianl info print message 0;

    err_num    = server.get_severity_count(UVM_ERROR);
    war_num    = server.get_severity_count(UVM_WARNING);
    fatal_num  = server.get_severity_count(UVM_FATAL);

    if((err_num!=0)||(fatal_num!=0)) begin
         $display("TC FAILED.(warning:%0d,error:%0d,fatal:%0d)",war_num,err_num,fatal_num);
    end
    else begin
         $display("TC PASSED.(warning:%0d,error:%0d,fatal:%0d)",war_num,err_num,fatal_num);
    end
endfunction

function void tc_base::pre_abort();
    this.extract_phase(null);
    this.report_phase(null);
endfunction

